{
  "name": "@swapparel/api",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc && tsc-alias",
    "typecheck": "tsc --noEmit",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile api",
    "dev": "bun run --env-file=.env --watch src/index.ts",
    "start": "bun run --env-file=.env src/index.ts",
    "lint": "biome check .",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.2",
    "@orpc/experimental-publisher": "^1.14.6",
    "@orpc/openapi": "^1.14.6",
    "@swapparel/contracts": "workspace:*",
    "better-auth": "^1.6.20",
    "elysia": "^1.4.29",
    "file-type": "^22.0.1",
    "heic-convert": "^2.1.0",
    "mongoose": "^8.24.0",
    "mongoose-zod": "https://github.com/ShreyasAyyengar/mongoose-zod#980604c491610053176be839645055a97e140af4",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "sharp": "^0.35.2",
    "uuid": "^14.0.1"
  },
  "exports": {
    "./auth-server": "./src/libs/auth-server.ts"
  },
  "devDependencies": {
    "@types/node": "^25.9.4",
    "tsc-alias": "^1.8.17"
  }
}
