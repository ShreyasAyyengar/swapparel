{
  "name": "@swapparel/api",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc && tsc-alias",
    "typecheck": "tsc --noEmit",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile api",
    "dev": "bun run --env-file=.env --watch src/index.ts",
    "start": "bun run --env-file=.env src/index.ts",
    "lint": "biome check .",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.948.0",
    "@aws-sdk/s3-request-presigner": "^3.948.0",
    "@elysiajs/cors": "^1.4.2",
    "@orpc/experimental-publisher": "^1.14.3",
    "@orpc/openapi": "^1.12.3",
    "@swapparel/contracts": "workspace:*",
    "better-auth": "^1.4.7",
    "elysia": "^1.4.28",
    "mongoose": "^8.20.2",
    "mongoose-zod": "https://github.com/ShreyasAyyengar/mongoose-zod",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.3",
    "uuid": "^14.0.0"
  },
  "exports": {
    "./auth-server": "./src/libs/auth-server.ts"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "bun-types": "^1.3.14",
    "tsc-alias": "^1.8.17"
  }
}
